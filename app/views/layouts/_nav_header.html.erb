<nav class="bg-gradient-to-r from-indigo-600 to-violet-600 text-white shadow-lg fixed w-full z-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex justify-between items-center h-16">
      
      <!-- Logo -->
      <%= link_to root_path, class: "flex items-center gap-3 group" do %>
        <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-indigo-600 font-bold text-2xl transition-transform group-hover:rotate-12">
          MAP
        </div>
        <span class="font-bold text-2xl tracking-tight">MindAtPlay</span>
      <% end %>

      <div class="flex items-center gap-8">
        <%= link_to "Игры", games_path, class: "hover:text-white/80 transition font-medium" %>

        <div class="flex items-center gap-4">
          <% if Current.user %>
            <div class="flex items-center gap-3">
              <span class="text-sm opacity-90"><%= Current.user.nickname || Current.user.email_address %></span>
              
              <%= link_to "Профиль", user_path(Current.user), class: "hover:text-white/80 transition" %>
              
              <%= button_to "Выйти", session_path, method: :delete,
                           class: "px-5 py-2 bg-white/10 hover:bg-white/20 rounded-xl text-sm font-medium transition backdrop-blur-sm" %>
            </div>
          <% else %>
            <div class="flex items-center gap-3">
              <%= link_to "Войти", new_session_path, class: "hover:text-white/80 transition font-medium" %>
              <%= link_to "Регистрация", new_registration_path, 
                         class: "px-6 py-2.5 bg-white text-indigo-600 font-semibold rounded-2xl hover:bg-white/90 transition shadow-sm" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</nav>